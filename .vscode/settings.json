{
  // Hide files that are not needed to be shown in the file explorer
  "files.exclude": {
    "**.mjs": true, // CommonJS modules
    "**.lock": true, // Bun lock file
    "**/.next": true, // Next.js build folder
    ".prettierrc": true, // Prettier config
    "next-env.d.ts": true, // Next.js internal types
    "**/node_modules": true // Node.js modules
  },

  "typescript.tsdk": "node_modules/typescript/lib",

  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  }
}
